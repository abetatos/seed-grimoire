# Generated books are ignored, except book-01 of "el-vitral", which is
# kept in-repo as a worked example (setup + plan + canon + cover).
# Its build/ output (compiled EPUB) stays ignored via the build/ rule below.
output/*
!output/el-vitral
data/
.env
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
.claude/settings.local.json

# Per-chapter /clear sentinel (transient; consumed by the Stop hook)
.clear-pending
**/.clear-pending

# Regeneratable per-chapter context bundles (rebuilt by build_context.py on
# demand; heavy and never authoritative — keep them out of the repo)
**/notes/_context-ch*.md
