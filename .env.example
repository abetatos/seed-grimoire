# The Seed Grimoire — copy to `.env` and fill in. `.env` is git-ignored.

# Your personal "Send to Kindle" address.
# Find it at: Amazon → Manage Your Content and Devices → Devices → your Kindle.
KINDLE_EMAIL=yourname_xxxxxx@kindle.com

# SMTP account used to email the EPUB to your Kindle.
# The FROM address MUST be on Amazon's "Approved Personal Document E-mail List".
# Gmail: create an App Password (Account → Security → App Passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
# Defaults to SMTP_USER if left blank.
SMTP_FROM=
